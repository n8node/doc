# Database - PostgreSQL 16 (Docker: postgres:16-alpine)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dropbox_ru?schema=public"

# NextAuth
NEXTAUTH_URL="https://qoqon.ru"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ВКонтакте OAuth (опционально, если не задано в админке → Авторизация → ВКонтакте)
# VK_CLIENT_ID=""
# VK_CLIENT_SECRET=""
# Включить VK, даже если в БД выключено «Разрешить вход через VK» (например после сбоя флага)
# VK_OAUTH_ENABLED="true"
# classic = oauth.vk.com (старые приложения ВК), vkid = id.vk.ru + PKCE (кабинет VK ID). Перекрывает админку.
# VK_OAUTH_PROTOCOL="vkid"

# Приложение
APP_URL="https://qoqon.ru"

# S3-совместимое хранилище (Beget, Yandex Cloud, SberCloud, Selectel)
# Приоритет: AdminConfig в БД > .env (иначе дефолты из кода)
S3_ENDPOINT=""
S3_REGION="ru-central1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_FORCE_PATH_STYLE="true"

# ЮKassa
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_WEBHOOK_SECRET=""

# Robokassa — в основном настройки в админке «Платежи»; при необходимости fallback через CONFIG_* см. config-store
# Язык страницы оплаты Robokassa (ru / en)
# ROBOKASSA_CULTURE="ru"

# AI провайдеры (YandexGPT, GigaChat, Ollama) - через админку
AI_DEFAULT_PROVIDER=""
AI_VECTOR_STORE_ENABLED="false"

# Docling - сервис обработки документов (OCR, парсинг PDF/DOCX/etc.)
DOCLING_URL="http://localhost:8000"
DOCLING_MAX_FILE_SIZE_MB="100"

# ONLYOFFICE Document Server (редактирование docx/xlsx/pptx в «Файлах»)
# Тот же секрет, что в JWT_ENABLED на контейнере onlyoffice (docker-compose).
ONLYOFFICE_JWT_SECRET="минимум-8-символов-совпадает-с-documentserver"
# Публичный базовый URL Document Server (без завершающего /). Префикс /onlyoffice/
# Не кладите в git строку с localhost — на проде после git pull подставится localhost. Для npm run dev см. .env.development.
# Дефолт в docker-compose: https://qoqon.ru/onlyoffice (переопределите при другом домене).
ONLYOFFICE_DOCUMENT_SERVER_URL="https://qoqon.ru/onlyoffice"
# Куда Next проксирует /onlyoffice/* (rewrites). В Docker: http://onlyoffice. Локально: http://127.0.0.1:8088
# ONLYOFFICE_INTERNAL_ORIGIN="http://127.0.0.1:8088"
# Отключить rewrite в next.config (если весь трафик /onlyoffice/ отдаёт внешний nginx): ONLYOFFICE_REWRITE=false
# Next/middleware: те же пути. WebSocket на внешний DS Next не проксирует — на проде обязательны location в nginx
# на /coauthoring/, /web-apps/ и др. (см. docker/nginx/default.conf и host-ubuntu-onlyoffice.example.conf).
# Редирект на /welcome в коде нет — если видите, проверьте nginx на сервере и панель хостинга (Beget и т.п.).
# APP_INTERNAL_URL="http://app:3000"
# Скачивание для DS: по умолчанию https APP_URL (см. env.ts). Только Docker-сеть без публичного URL:
# ONLYOFFICE_DOCUMENT_DOWNLOAD_BASE_URL="http://app:3000"
# В docker-compose у onlyoffice задано ALLOW_PRIVATE_IP_ADDRESS=true — иначе DS блокирует скачивание по приватным IP (скелет в редакторе).

# Шифрование секретов в AdminConfig (VK, S3, почта, …). На проде задайте один раз и НЕ меняйте:
# при смене ключа старые зашифрованные значения в БД перестанут расшифровываться (до повторного ввода в админке).
# В docker-compose ключ проброшен в app явно — держите его в серверном .env рядом с compose.
CONFIG_ENCRYPTION_KEY="32-byte-hex-key-for-aes-256"

# Секрет для служебных POST /api/v1/cron/* (calendar-bridge-sync, openrouter-balance-telegram, …)
# CRON_SECRET="длинная-случайная-строка"

# Telegram бот для входа через QR (иначе — через админку)
# TELEGRAM_BOT_TOKEN="123456:ABC..."
# Автозапуск бота при перезагрузке контейнера (без кнопки в админе)
# TELEGRAM_BOT_AUTO_START="true"

# Redis (опционально, для сессий/очередей)
REDIS_URL="redis://localhost:6379"

# n8n PostgreSQL (вариант по умолчанию) — текущий сервер DOC
# Встроенный контейнер n8n-db:
#   N8N_DB_PASSWORD=надёжный_пароль
#   N8N_DB_URL=postgresql://n8n_admin:НАДЁЖНЫЙ_ПАРОЛЬ@n8n-db:5432/n8n_db
# Внешние реквизиты для пользователей n8n:
#   N8N_DB_PUBLIC_HOST=qoqon.ru
#   N8N_DB_PUBLIC_PORT=5433
#
# n8n PostgreSQL (РФ сервер, опционально)
#   N8N_DB_URL_RF=postgresql://cloud_user:X%21PcxYZ%2AzM0Y@lecegomuru.beget.app:5432/n8n_db?sslmode=require
#   N8N_DB_PUBLIC_HOST_RF=lecegomuru.beget.app
#   N8N_DB_PUBLIC_PORT_RF=5432

# Парсинг сайтов (dashboard → Парсинг): отключить headless Chromium (только обычный fetch)
# WEB_IMPORT_PLAYWRIGHT="0"
