model SupportTicketTheme {
  id        String   @id @default(cuid()) @map("id")
  name      String   @unique @map("name")
  slug      String   @unique @map("slug")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  tickets   SupportTicket[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("support_ticket_themes")
}

model SupportTicket {
  id        String          @id @default(cuid()) @map("id")
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId   String          @map("theme_id")
  theme     SupportTicketTheme @relation(fields: [themeId], references: [id])
  subject   String?         @map("subject")
  status    TicketStatus    @default(AWAITING_ADMIN) @map("status")
  messages  SupportTicketMessage[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([themeId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id         String             @id @default(cuid()) @map("id")
  ticketId   String             @map("ticket_id")
  ticket     SupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String             @map("author_id")
  authorRole TicketMessageAuthor @map("author_role")
  body       String             @db.Text @map("body")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("support_ticket_messages")
}

/// Импорт страниц с веб-сайтов (скрейп, обход, список ссылок)
model WebImportJob {
  id                String   @id @default(cuid()) @map("id")
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode              String   @map("mode") // single | crawl | batch | links_only
  status            String   @map("status") // pending | running | completed | cancelled | failed
  cancelRequested   Boolean  @default(false) @map("cancel_requested")
  input             Json     @map("input") // { startUrl?, maxPages?, urls?, sameDomainOnly? }
  state             Json?    @map("state") // crawlQueue, visited, batchIndex — служебное
  pages             Json     @default("[]") @map("pages") // массив страниц/результатов
  errorMessage      String?  @map("error_message") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("web_import_jobs")
}

model Notification {
  id        String           @id @default(cuid()) @map("id")
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @map("type")
  category  String           @map("category") // "info" | "warning" | "success" | "error"
  title     String           @map("title")
  body      String?          @map("body")
  payload   Json?            @map("payload") // { fileId?, linkId?, percent?, ... }
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

/// Шаги дорожной карты продукта (публичная страница /roadmap)
model RoadmapStep {
  id         String   @id @default(cuid()) @map("id")
  title      String   @map("title")
  targetDate DateTime @map("target_date") @db.Date
  sortOrder  Int      @map("sort_order")
  completed  Boolean  @default(false) @map("completed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@index([targetDate])
  @@map("roadmap_steps")
}
