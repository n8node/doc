// Prisma schema для Dropbox-подобного сервиса (qoqon.ru)
// PostgreSQL 16 с расширениями pgcrypto, pgvector

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid()) @map("id")
  email        String      @unique @map("email")
  passwordHash String      @map("password_hash")
  name         String?     @map("name")
  role         Role        @default(USER) @map("role")
  isBlocked    Boolean     @default(false) @map("is_blocked")
  blockedAt    DateTime?   @map("blocked_at")
  lastLoginAt  DateTime?   @map("last_login_at")
  storageUsed  BigInt      @default(0) @map("storage_used")
  storageQuota BigInt      @default(26843545600) @map("storage_quota") // 25GB
  maxFileSize  BigInt      @default(536870912) @map("max_file_size") // 512MB
  planId       String?     @map("plan_id")
  plan         Plan?       @relation(fields: [planId], references: [id])
  files        File[]
  folders      Folder[]
  payments     Payment[]
  aiTasks      AiTask[]
  shareLinks   ShareLink[]
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("users")
}

model File {
  id            String      @id @default(cuid()) @map("id")
  name          String      @map("name")
  mimeType      String      @map("mime_type")
  size          BigInt      @map("size")
  s3Key         String      @map("s3_key")
  folderId      String?     @map("folder_id")
  folder        Folder?     @relation(fields: [folderId], references: [id])
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id])
  isShared      Boolean     @default(false) @map("is_shared")
  sharedLink    String?     @unique @map("shared_link")
  hasEmbedding  Boolean     @default(false) @map("has_embedding")
  aiMetadata    Json?       @map("ai_metadata")
  mediaMetadata Json?       @map("media_metadata")
  shareLinks    ShareLink[]
  embeddings    DocumentEmbedding[]
  aiTasks       AiTask[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("files")
  @@index([userId, folderId])
}

model Folder {
  id         String      @id @default(cuid()) @map("id")
  name       String      @map("name")
  parentId   String?     @map("parent_id")
  parent     Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id])
  children   Folder[]    @relation("FolderHierarchy")
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id])
  files      File[]
  shareLinks ShareLink[]
  createdAt  DateTime    @default(now()) @map("created_at")

  @@map("folders")
  @@index([userId, parentId])
}

model ShareLink {
  id          String    @id @default(cuid()) @map("id")
  token       String    @unique @map("token")
  targetType  String    @map("target_type") // "FILE" | "FOLDER"
  fileId      String?   @map("file_id")
  file        File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folderId    String?   @map("folder_id")
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? @map("expires_at")
  oneTime     Boolean   @default(false) @map("one_time")
  usedAt      DateTime? @map("used_at")
  createdById String    @map("created_by_id")
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("share_links")
  @@index([createdById])
}

model Plan {
  id             String    @id @default(cuid()) @map("id")
  name           String    @unique @map("name")
  isFree         Boolean   @default(false) @map("is_free")
  storageQuota   BigInt    @map("storage_quota")
  maxFileSize    BigInt    @default(536870912) @map("max_file_size") // 512MB
  features       Json?     @map("features") // { "video_player": true, "audio_player": true, ... }
  priceMonthly   Int?      @map("price_monthly")
  priceYearly    Int?      @map("price_yearly")
  sortOrder      Int       @default(0) @map("sort_order")
  isPopular      Boolean   @default(false) @map("is_popular")
  yookassaPlanId String?   @map("yookassa_plan_id")
  users          User[]
  payments       Payment[]

  @@map("plans")
}

model Payment {
  id                String        @id @default(cuid()) @map("id")
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id])
  planId            String        @map("plan_id")
  plan              Plan          @relation(fields: [planId], references: [id])
  amount            Int           @map("amount")
  currency          String        @default("RUB") @map("currency")
  status            PaymentStatus @map("status")
  yookassaPaymentId String?       @unique @map("yookassa_payment_id")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@map("payments")
}

model AdminConfig {
  id          String   @id @default(cuid()) @map("id")
  key         String   @unique @map("key") // "s3.endpoint", "ai.yandex.api_key"
  value       String   @map("value") // зашифрованное или открытое
  isEncrypted Boolean  @default(false) @map("is_encrypted")
  description String?  @map("description")
  category    String   @default("general") @map("category") // "storage", "payments", "ai"
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_config")
  @@index([category])
}

model AiProvider {
  id        String         @id @default(cuid()) @map("id")
  name      String         @unique @map("name")
  type      AiProviderType @map("type")
  baseUrl   String?        @map("base_url")
  modelName String?        @map("model_name")
  apiKey    String?        @map("api_key") // зашифровано
  folderId  String?        @map("folder_id") // Yandex Cloud
  isActive  Boolean        @default(false) @map("is_active")
  config    Json?          @map("config") // { temperature, max_tokens, ... }
  tasks     AiTask[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@map("ai_providers")
}

model DocumentEmbedding {
  id         String   @id @default(cuid()) @map("id")
  fileId     String   @map("file_id")
  file       File     @relation(fields: [fileId], references: [id])
  vector     Json     @map("vector") // float[] для pgvector
  contentHash String  @map("content_hash")
  chunkIndex Int      @map("chunk_index")
  metadata   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("document_embeddings")
  @@index([fileId])
}

model AiTask {
  id          String      @id @default(cuid()) @map("id")
  type        AiTaskType  @map("type")
  status      TaskStatus  @map("status")
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id])
  fileId      String?     @map("file_id")
  file        File?       @relation(fields: [fileId], references: [id])
  input       Json       @map("input")
  output      Json?      @map("output")
  error       String?    @map("error")
  providerId  String?    @map("provider_id")
  provider    AiProvider? @relation(fields: [providerId], references: [id])
  createdAt   DateTime   @default(now()) @map("created_at")
  startedAt   DateTime?  @map("started_at")
  completedAt DateTime?  @map("completed_at")

  @@map("ai_tasks")
  @@index([fileId, status])
  @@index([providerId, status])
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  pending
  succeeded
  canceled
  refunded
}

enum AiProviderType {
  CLOUD
  SELF_HOSTED
  LOCAL
}

enum AiTaskType {
  EMBEDDING
  ANALYSIS
  OCR
  SUMMARIZE
  CLASSIFY
}

enum TaskStatus {
  pending
  processing
  completed
  failed
  cancelled
}
