// Prisma schema для Dropbox-подобного сервиса (qoqon.ru)
// PostgreSQL 16 с расширениями pgcrypto, pgvector

generator client {
  provider      = "prisma-client-js"
  // native — локальная разработка; debian-openssl-3.0.x — Docker node:20-bookworm-slim (OpenSSL 3)
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid()) @map("id")
  email                String                @unique @map("email")
  isEmailVerified      Boolean               @default(true) @map("is_email_verified")
  emailVerifiedAt      DateTime?             @map("email_verified_at")
  passwordHash         String                @map("password_hash")
  name                 String?               @map("name")
  role                 Role                  @default(USER) @map("role")
  isBlocked            Boolean               @default(false) @map("is_blocked")
  blockedAt            DateTime?             @map("blocked_at")
  lastLoginAt          DateTime?             @map("last_login_at")
  storageUsed          BigInt                @default(0) @map("storage_used")
  storageQuota         BigInt                @default(26843545600) @map("storage_quota") // 25GB
  llmWalletBalanceCents Int                  @default(0) @map("llm_wallet_balance_cents") // баланс маркетплейса LLM (копейки)
  maxFileSize          BigInt                @default(536870912) @map("max_file_size") // 512MB
  planId               String?               @map("plan_id")
  plan                 Plan?                 @relation(fields: [planId], references: [id])
  files                File[]
  folders              Folder[]
  payments             Payment[]
  aiTasks              AiTask[]
  shareLinks           ShareLink[]
  shareGrantsOwned     ShareGrant[]          @relation("ShareGrantOwner")
  shareGrantsReceived  ShareGrant[]          @relation("ShareGrantRecipient")
  historyEvents        HistoryEvent[]
  documentChatMessages DocumentChatMessage[]
  apiKeys              UserApiKey[]
  userAiConfig         UserAiConfig?
  notifications        Notification[]
  vectorCollections    VectorCollection[]
  tokenUsageEvents     TokenUsageEvent[]
  n8nPgConnections     N8nPgConnection[]
  llmApiKeys           UserLlmApiKey[]
  llmWalletTopups      LlmWalletTopup[]
  marketplaceUsage     MarketplaceUsageEvent[]
  sheets               Sheet[]
  n8nTableConnections  N8nTableConnection[]
  preferences          Json?                 @map("preferences") // { theme?: string, notifications?: { storage, trash, payment, ... } }
  telegramUserId       BigInt?               @unique @map("telegram_user_id")
  telegramUsername     String?               @map("telegram_username")
  vkUserId             BigInt?               @unique @map("vk_user_id")
  vkScreenName         String?               @map("vk_screen_name")
  registeredViaInviteId String?              @map("registered_via_invite_id")
  registeredViaInvite  Invite?               @relation("UserRegisteredViaInvite", fields: [registeredViaInviteId], references: [id], onDelete: SetNull)
  emailVerificationTokens EmailVerificationToken[]
  createdInvites       Invite[]              @relation("InviteCreatedByUser")
  usedInvites          Invite[]              @relation("InviteUsedByUser")
  ownedInvites         Invite[]              @relation("InviteOwnedByUser")
  spamAlerts           SpamAlertEvent[]
  supportTickets       SupportTicket[]
  imageGenerationTasks ImageGenerationTask[]
  webImportJobs        WebImportJob[]
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@index([registeredViaInviteId])
  @@map("users")
}

model SpamAlertEvent {
  id                 String            @id @default(cuid()) @map("id")
  rootUserId         String?           @map("root_user_id")
  rootUser           User?             @relation(fields: [rootUserId], references: [id], onDelete: SetNull)
  severity           SpamAlertSeverity @map("severity")
  score              Int               @map("score")
  registrationsCount Int               @map("registrations_count")
  verificationRate   Float             @map("verification_rate")
  activityRate       Float             @map("activity_rate")
  uniqueDomains      Int               @map("unique_domains")
  windowStart        DateTime          @map("window_start")
  windowEnd          DateTime          @map("window_end")
  cooldownKey        String            @unique @map("cooldown_key")
  sentToTelegram     Boolean           @default(false) @map("sent_to_telegram")
  details            Json?             @map("details")
  createdAt          DateTime          @default(now()) @map("created_at")

  @@index([rootUserId, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@map("spam_alert_events")
}

model EmailVerificationToken {
  id              String                   @id @default(cuid()) @map("id")
  userId          String                   @map("user_id")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose         EmailVerificationPurpose @map("purpose")
  tokenHash       String                   @unique @map("token_hash")
  newEmail        String?                  @map("new_email")
  newPasswordHash String?                  @map("new_password_hash")
  expiresAt       DateTime                 @map("expires_at")
  usedAt          DateTime?                @map("used_at")
  createdAt       DateTime                 @default(now()) @map("created_at")

  @@index([userId, purpose, createdAt(sort: Desc)])
  @@index([purpose, expiresAt])
  @@index([newEmail])
  @@map("email_verification_tokens")
}

model Invite {
  id              String      @id @default(cuid()) @map("id")
  code            String      @unique @map("code")
  scope           InviteScope @map("scope")
  status          InviteStatus @default(ACTIVE) @map("status")
  ownerUserId     String?     @map("owner_user_id")
  ownerUser       User?       @relation("InviteOwnedByUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  createdByUserId String?     @map("created_by_user_id")
  createdByUser   User?       @relation("InviteCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  usedByUserId    String?     @map("used_by_user_id")
  usedByUser      User?       @relation("InviteUsedByUser", fields: [usedByUserId], references: [id], onDelete: SetNull)
  registeredUsers User[]      @relation("UserRegisteredViaInvite")
  usedAt          DateTime?   @map("used_at")
  expiresAt       DateTime?   @map("expires_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@index([scope, status, createdAt(sort: Asc)])
  @@index([ownerUserId, status, createdAt(sort: Desc)])
  @@map("invites")
}

model File {
  id                    String                 @id @default(cuid()) @map("id")
  name                  String                 @map("name")
  mimeType              String                 @map("mime_type")
  size                  BigInt                 @map("size")
  s3Key                 String                 @map("s3_key")
  folderId              String?                @map("folder_id")
  folder                Folder?                @relation(fields: [folderId], references: [id])
  userId                String                 @map("user_id")
  user                  User                   @relation(fields: [userId], references: [id])
  isShared              Boolean                @default(false) @map("is_shared")
  sharedLink            String?                @unique @map("shared_link")
  hasEmbedding          Boolean                @default(false) @map("has_embedding")
  aiMetadata            Json?                  @map("ai_metadata")
  mediaMetadata         Json?                  @map("media_metadata")
  deletedAt             DateTime?              @map("deleted_at")
  trashBatchId          String?                @map("trash_batch_id")
  shareLinks            ShareLink[]
  shareGrants           ShareGrant[]
  embeddings            DocumentEmbedding[]
  aiTasks               AiTask[]
  chatMessages          DocumentChatMessage[]
  vectorCollectionFiles VectorCollectionFile[]
  sheetsFromFile        Sheet[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@index([userId, folderId])
  @@index([userId, deletedAt])
  @@map("files")
}

model Folder {
  id                String             @id @default(cuid()) @map("id")
  name              String             @map("name")
  parentId          String?            @map("parent_id")
  parent            Folder?            @relation("FolderHierarchy", fields: [parentId], references: [id])
  children          Folder[]           @relation("FolderHierarchy")
  userId            String             @map("user_id")
  user              User               @relation(fields: [userId], references: [id])
  files             File[]
  shareLinks        ShareLink[]
  shareGrants       ShareGrant[]
  vectorCollections VectorCollection[]
  deletedAt         DateTime?          @map("deleted_at")
  trashBatchId      String?            @map("trash_batch_id")
  createdAt         DateTime           @default(now()) @map("created_at")

  @@index([userId, parentId])
  @@index([userId, deletedAt])
  @@map("folders")
}

model UserApiKey {
  id         String    @id @default(cuid()) @map("id")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String    @map("name")
  keyToken   String    @unique @map("key_token") // qk_<keyToken>__<secret>, for lookup
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_api_keys")
}

model UserLlmApiKey {
  id         String    @id @default(cuid()) @map("id")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String    @map("name")
  keyToken   String    @unique @map("key_token")
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix") // QoQon_LLM_xxx...
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_llm_api_keys")
}

model LlmWalletTopup {
  id                  String   @id @default(cuid()) @map("id")
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents         Int      @map("amount_cents")
  status              String   @map("status") // pending | succeeded | canceled
  yookassaPaymentId   String?  @unique @map("yookassa_payment_id")
  createdAt           DateTime @default(now()) @map("created_at")
  succeededAt         DateTime? @map("succeeded_at")

  @@index([userId])
  @@map("llm_wallet_topups")
}

model MarketplaceUsageEvent {
  id           String   @id @default(cuid()) @map("id")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  llmKeyId     String?  @map("llm_key_id")
  category     String   @map("category") // chat | embeddings | image | audio | video
  model        String   @map("model")
  tokensIn     Int      @default(0) @map("tokens_in")
  tokensOut    Int      @default(0) @map("tokens_out")
  costCents    Int      @map("cost_cents")
  metadata     Json?    @map("metadata")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([llmKeyId, createdAt(sort: Desc)])
  @@map("marketplace_usage_events")
}

// Таблицы (спредшиты) — TanStack Table, импорт Excel, n8n Postgres
model Sheet {
  id                 String                 @id @default(cuid()) @map("id")
  userId             String                 @map("user_id")
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String                 @map("name")
  sourceFileId       String?                @map("source_file_id")
  sourceFile         File?                  @relation(fields: [sourceFileId], references: [id], onDelete: SetNull)
  columns            SheetColumn[]
  cells              SheetCell[]
  n8nTableConnections N8nTableConnection[]
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  @@index([userId])
  @@index([sourceFileId])
  @@map("sheets")
}

model SheetColumn {
  id       String    @id @default(cuid()) @map("id")
  sheetId  String    @map("sheet_id")
  sheet    Sheet     @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  order    Int       @default(0) @map("order")
  name     String    @map("name")
  dataType String    @default("text") @map("data_type") // text | number | boolean | date | datetime | select
  config   Json?     @map("config") // { decimals?, min?, max?, options?, format? }
  cells    SheetCell[]
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sheetId])
  @@map("sheet_columns")
}

model SheetCell {
  id         String      @id @default(cuid()) @map("id")
  sheetId    String      @map("sheet_id")
  sheet      Sheet       @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  columnId   String      @map("column_id")
  column     SheetColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  rowIndex   Int         @map("row_index")
  value      String?     @map("value") // stored as string; type interpretation from column.dataType
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@unique([sheetId, columnId, rowIndex])
  @@index([sheetId])
  @@index([columnId])
  @@map("sheet_cells")
}

model N8nTableConnection {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheetId         String   @map("sheet_id")
  sheet           Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  dbRoleName      String   @unique @map("db_role_name")
  dbPasswordHash  String   @map("db_password_hash")
  tableName       String   @map("table_name")
  target          String   @default("DEFAULT") @map("target")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([sheetId])
  @@map("n8n_table_connections")
}

model ShareLink {
  id          String    @id @default(cuid()) @map("id")
  token       String    @unique @map("token")
  targetType  String    @map("target_type") // "FILE" | "FOLDER"
  fileId      String?   @map("file_id")
  file        File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folderId    String?   @map("folder_id")
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? @map("expires_at")
  oneTime     Boolean   @default(false) @map("one_time")
  usedAt      DateTime? @map("used_at")
  createdById String    @map("created_by_id")
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdById])
  @@map("share_links")
}

enum ShareGrantStatus {
  PENDING
  ACTIVE
  DECLINED
  REVOKED
  EXPIRED
}

/// Совместный доступ по email (не публичная ссылка).
model ShareGrant {
  id                 String           @id @default(cuid()) @map("id")
  ownerUserId        String           @map("owner_user_id")
  owner              User             @relation("ShareGrantOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  recipientEmail     String           @map("recipient_email") // lowercased
  recipientUserId    String?          @map("recipient_user_id")
  recipient          User?            @relation("ShareGrantRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  targetType         String           @map("target_type") // FILE | FOLDER
  shareTargetKey     String           @map("share_target_key") // file:<id> или folder:<id>
  fileId             String?          @map("file_id")
  file               File?            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folderId           String?          @map("folder_id")
  folder             Folder?          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  status             ShareGrantStatus @default(PENDING) @map("status")
  allowCollections   Boolean          @default(false) @map("allow_collections")
  allowAiFeatures    Boolean          @default(false) @map("allow_ai_features")
  expiresAt          DateTime?        @map("expires_at")
  acceptedAt         DateTime?        @map("accepted_at")
  declinedAt         DateTime?        @map("declined_at")
  revokedAt          DateTime?        @map("revoked_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([ownerUserId, status])
  @@index([recipientUserId, status])
  @@index([recipientEmail, status])
  @@index([expiresAt])
  @@unique([ownerUserId, recipientEmail, shareTargetKey])
  @@map("share_grants")
}

model HistoryEvent {
  id        String   @id @map("id")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   @map("action")
  summary   String   @map("summary")
  payload   Json?    @map("payload")
  batchId   String?  @map("batch_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([batchId])
  @@map("history_events")
}

model Plan {
  id                           String      @id @default(cuid()) @map("id")
  name                         String      @unique @map("name")
  isFree                       Boolean     @default(false) @map("is_free")
  storageQuota                 BigInt      @map("storage_quota")
  maxFileSize                  BigInt      @default(536870912) @map("max_file_size") // 512MB
  trashRetentionDays           Int         @default(0) @map("trash_retention_days")
  embeddingTokensQuota         Int?        @map("embedding_tokens_quota") // токенов на эмбеддинг в месяц, null = без лимита
  chatTokensQuota              Int?        @map("chat_tokens_quota") // токенов чата по документам в месяц, null = без лимита
  searchTokensQuota            Int?        @map("search_tokens_quota") // токенов поиска в месяц, null = без лимита
  aiAnalysisDocumentsQuota     Int?        @map("ai_analysis_documents_quota") // документов AI-анализа в месяц, null = без лимита
  ragDocumentsQuota            Int?        @map("rag_documents_quota") // документов RAG-коллекций, null = без лимита
  freePlanDurationDays         Int?        @map("free_plan_duration_days") // срок действия бесплатного тарифа в днях (24 часа), null = без ограничения
  features                     Json?       @map("features") // { "video_player": true, "transcription": true, "document_analysis": true, ... }
  transcriptionMinutesQuota    Int?        @map("transcription_minutes_quota") // минут транскрипции в месяц, null = без лимита
  maxTranscriptionVideoMinutes Int         @default(60) @map("max_transcription_video_minutes") // макс. длительность видео в одном файле
  maxTranscriptionAudioMinutes Int         @default(120) @map("max_transcription_audio_minutes") // макс. длительность аудио в одном файле
  transcriptionProviderId      String?     @map("transcription_provider_id") // премиум-провайдер, null = Docling/Whisper
  transcriptionProvider        AiProvider? @relation("PlanTranscriptionProvider", fields: [transcriptionProviderId], references: [id])
  imageGenerationCreditsQuota   Int?        @map("image_generation_credits_quota") // кредитов на генерацию в месяц по тарифу, null = без лимита/отключено
  webImportPagesQuota          Int?        @map("web_import_pages_quota") // страниц парсинга сайтов в месяц, null = без лимита
  priceMonthly                 Int?        @map("price_monthly")
  priceYearly                  Int?        @map("price_yearly")
  sortOrder                    Int         @default(0) @map("sort_order")
  isPopular                    Boolean     @default(false) @map("is_popular")
  yookassaPlanId               String?     @map("yookassa_plan_id")
  users                        User[]
  payments                     Payment[]

  @@map("plans")
}

model Payment {
  id                String        @id @default(cuid()) @map("id")
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id])
  planId            String        @map("plan_id")
  plan              Plan          @relation(fields: [planId], references: [id])
  amount            Int           @map("amount")
  currency          String        @default("RUB") @map("currency")
  status            PaymentStatus @map("status")
  yookassaPaymentId String?       @unique @map("yookassa_payment_id")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@map("payments")
}

model AdminConfig {
  id          String   @id @default(cuid()) @map("id")
  key         String   @unique @map("key") // "s3.endpoint", "ai.yandex.api_key"
  value       String   @map("value") // зашифрованное или открытое
  isEncrypted Boolean  @default(false) @map("is_encrypted")
  description String?  @map("description")
  category    String   @default("general") @map("category") // "storage", "payments", "ai"
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("admin_config")
}

model ImageGenerationTask {
  id           String    @id @default(cuid()) @map("id")
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kieTaskId    String?   @map("kie_task_id") // null пока задача в очереди
  modelId      String    @map("model_id")
  variant      String?   @map("variant") // напр. flux-kontext-pro, flux-kontext-max
  taskType     String    @map("task_type") // text_to_image | edit_image | variations
  status       String    @map("status") // queued | processing | success | failed
  costCredits  Int?      @map("cost_credits")
  billedCredits Int?     @map("billed_credits") // с наценкой, для учёта квоты и биллинга
  resultUrl    String?   @map("result_url")
  fileId       String?   @map("file_id") // после автосохранения на диск
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([kieTaskId])
  @@map("image_generation_tasks")
}

model ImageGenerationQueue {
  id        String   @id @default(cuid()) @map("id")
  taskId    String   @unique @map("task_id") // FK ImageGenerationTask
  kind      String   @map("kind") // 4o | flux | market
  payload   Json     @map("payload") // тело запроса для повторной отправки в Kie
  status    String   @map("status") // pending | sent
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt(sort: Asc)])
  @@map("image_generation_queue")
}

model KiePricing {
  id           String    @id @default(cuid()) @map("id")
  modelId      String    @map("model_id") // наш id модели, напр. kie-4o-image, kie-flux-kontext
  variant      String?   @map("variant") // напр. flux-kontext-pro, flux-kontext-max
  priceCredits Int      @map("price_credits")
  priceUsd     Float?   @map("price_usd")
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  @@unique([modelId, variant])
  @@index([modelId])
  @@map("kie_pricing")
}

model OpenRouterTopupBatch {
  id                    String   @id @default(cuid()) @map("id")
  usdAmount             Float    @map("usd_amount")
  rubSpentCents         Int      @map("rub_spent_cents")
  rubFeeCents           Int      @default(0) @map("rub_fee_cents")
  effectiveRateRubPerUsd Float   @map("effective_rate_rub_per_usd")
  usdRemaining          Float    @map("usd_remaining")
  source                String?  @map("source")
  comment               String?  @map("comment")
  toppedAt              DateTime @map("topped_at")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([toppedAt(sort: Desc)])
  @@map("open_router_topup_batches")
}

model PlatformExpense {
  id          String   @id @default(cuid()) @map("id")
  category    String   @map("category") // server, s3, domain, ...
  type        String   @map("type") // fixed_monthly, variable_per_gb_day, ...
  amountCents Int      @map("amount_cents")
  unit        String?  @map("unit") // для variable: "gb_day", "gb_month"
  sinceAt     DateTime @map("since_at")
  comment     String?  @map("comment")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([sinceAt(sort: Desc)])
  @@map("platform_expenses")
}

model DocPage {
  id        String   @id @default(cuid()) @map("id")
  slug      String   @unique @map("slug")
  title     String   @map("title")
  content   String   @db.Text @map("content")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("doc_pages")
}

model PublicPage {
  id        String   @id @default(cuid()) @map("id")
  slug      String   @unique @map("slug")
  title     String   @map("title")
  content   String   @db.Text @map("content")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("public_pages")
}

model TelegramLoginToken {
  id                String   @id @default(cuid()) @map("id")
  token             String   @unique @map("token")
  linkUserId        String?  @map("link_user_id")
  telegramUserId    BigInt?  @map("telegram_user_id")
  telegramUsername  String?  @map("telegram_username")
  telegramFirstName String?  @map("telegram_first_name")
  telegramLastName  String?  @map("telegram_last_name")
  expiresAt         DateTime @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([expiresAt])
  @@index([linkUserId])
  @@map("telegram_login_tokens")
}

model UserAiConfig {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerName    String   @map("provider_name")
  baseUrl         String?  @map("base_url")
  apiKey          String?  @map("api_key")
  folderId        String?  @map("folder_id")
  embeddingModel  String   @map("embedding_model")
  chatModel       String   @map("chat_model")
  embeddingConfig Json?    @map("embedding_config") // defaults: { chunkSize, chunkOverlap, dimensions?, similarityThreshold?, topK? }
  isActive        Boolean  @default(false) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_ai_configs")
}

model AiProvider {
  id                           String            @id @default(cuid()) @map("id")
  name                         String            @unique @map("name")
  type                         AiProviderType    @map("type")
  purpose                      AiProviderPurpose @default(EMBEDDING_CHAT) @map("purpose") // EMBEDDING_CHAT | TRANSCRIPTION
  baseUrl                      String?           @map("base_url")
  modelName                    String?           @map("model_name") // модель эмбеддинга или транскрибации
  chatModelName                String?           @map("chat_model_name") // модель чата (только для EMBEDDING_CHAT)
  apiKey                       String?           @map("api_key") // зашифровано
  folderId                     String?           @map("folder_id") // Yandex Cloud
  isActive                     Boolean           @default(false) @map("is_active")
  config                       Json?             @map("config") // { temperature, max_tokens, language, ... }
  tasks                        AiTask[]
  plansAsTranscriptionProvider Plan[]            @relation("PlanTranscriptionProvider")
  createdAt                    DateTime          @default(now()) @map("created_at")
  updatedAt                    DateTime          @updatedAt @map("updated_at")

  @@map("ai_providers")
}

model DocumentChatMessage {
  id        String   @id @default(cuid()) @map("id")
  fileId    String   @map("file_id")
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @map("role") // "user" | "assistant"
  content   String   @map("content")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([fileId, userId])
  @@map("document_chat_messages")
}

model DocumentEmbedding {
  id          String                @id @default(cuid()) @map("id")
  fileId      String                @map("file_id")
  file        File                  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  vector      Unsupported("vector") @map("vector")
  chunkText   String                @map("chunk_text")
  contentHash String                @map("content_hash")
  chunkIndex  Int                   @map("chunk_index")
  metadata    Json?                 @map("metadata")
  createdAt   DateTime              @default(now()) @map("created_at")

  @@index([fileId])
  @@map("document_embeddings")
}

model VectorCollection {
  id               String                 @id @default(cuid()) @map("id")
  userId           String                 @map("user_id")
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String                 @map("name")
  folderId         String?                @map("folder_id")
  folder           Folder?                @relation(fields: [folderId], references: [id], onDelete: SetNull)
  embeddingConfig  Json?                  @map("embedding_config") // { chunkSize, chunkOverlap, dimensions?, similarityThreshold?, topK? }
  files            VectorCollectionFile[]
  n8nPgConnections N8nPgConnection[]
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([userId])
  @@map("vector_collections")
}

model N8nPgConnection {
  id           String           @id @default(cuid()) @map("id")
  userId       String           @map("user_id")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId String           @map("collection_id")
  collection   VectorCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  dbRoleName   String           @unique @map("db_role_name")
  dbPasswordHash String         @map("db_password_hash")
  viewName     String           @map("view_name")
  target       String           @default("DEFAULT") @map("target")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@index([collectionId])
  @@map("n8n_pg_connections")
}

model VectorCollectionFile {
  id           String           @id @default(cuid()) @map("id")
  collectionId String           @map("collection_id")
  collection   VectorCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  fileId       String           @map("file_id")
  file         File             @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([collectionId, fileId])
  @@index([collectionId])
  @@index([fileId])
  @@map("vector_collection_files")
}

model AiTask {
  id          String      @id @default(cuid()) @map("id")
  type        AiTaskType  @map("type")
  status      TaskStatus  @map("status")
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id])
  fileId      String?     @map("file_id")
  file        File?       @relation(fields: [fileId], references: [id])
  input       Json        @map("input")
  output      Json?       @map("output")
  error       String?     @map("error")
  providerId  String?     @map("provider_id")
  provider    AiProvider? @relation(fields: [providerId], references: [id])
  usedOwnKey  Boolean?    @default(false) @map("used_own_key")
  createdAt   DateTime    @default(now()) @map("created_at")
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")

  @@index([fileId, status])
  @@index([providerId, status])
  @@map("ai_tasks")
}

model TokenUsageEvent {
  id         String             @id @default(cuid()) @map("id")
  userId     String             @map("user_id")
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   TokenUsageCategory @map("category")
  provider   String?            @map("provider")
  model      String?            @map("model")
  sourceType String             @map("source_type") // "document_chat" | "search" | "embedding" | "transcription"
  sourceId   String?            @map("source_id")
  tokensIn   Int                @default(0) @map("tokens_in")
  tokensOut  Int                @default(0) @map("tokens_out")
  tokensTotal Int               @map("tokens_total")
  isBillable Boolean            @default(true) @map("is_billable") // false when user used own API key
  metadata   Json?              @map("metadata")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, category, createdAt(sort: Desc)])
  @@index([sourceType, sourceId])
  @@map("token_usage_events")
}

