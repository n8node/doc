# Database - PostgreSQL 16 (Docker: docker-compose up -d db)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dropbox_ru?schema=public"

# NextAuth (для qoqon.ru)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production"

# Приложение
APP_URL="http://localhost:3000"

# Шифрование секретов в AdminConfig
CONFIG_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# ONLYOFFICE — тот же секрет, что JWT_SECRET у контейнера onlyoffice (docker-compose)
ONLYOFFICE_JWT_SECRET="khihg76jk909304fjkhihg76jk909309304fjkhihg"
# Скрипт редактора: тот же хост:порт, что у Next (npm run dev / docker publish 3000). Не http://localhost/onlyoffice без :3000
ONLYOFFICE_DOCUMENT_SERVER_URL="http://localhost:3000/onlyoffice"
